BACKUP_ROOT=/srv/backups
DOCKER_DIR=/srv/docker
MYSQL_CONTAINER=mysql
# Optional: Logverzeichnis fuer Lauf- und Fehlerprotokolle
# Standard ohne Angabe: <projekt-root>/log
# LOG_DIR=/srv/restic/log

RESTIC_TAG=docker-backup
KEEP_DAILY=7
KEEP_WEEKLY=4
KEEP_MONTHLY=6
# Wie viele lokale Snapshot-Ordner in BACKUP_ROOT aufbewahrt werden sollen (standard: 1)
# Wenn 0, wird der lokale Ordner nach dem Restic-Backup sofort geloescht.
KEEP_LOCAL_BACKUPS=1

# Standardwerte fuer MySQL (optional, falls viele Instanzen gleich konfiguriert sind)
# MYSQL_DEFAULT_USER=backup
# MYSQL_DEFAULT_PASSWORD=passwort_aus_env

# Liste der zu sichernden MySQL-Instanzen
# Format: "CONTAINER_NAME:USER:PASSWORD:PORT"
# Wenn USER, PASSWORD oder PORT leer sind, werden die Standardwerte genutzt.
# PORT ist standardmaessig 3306.
MYSQL_INSTANCES=(
  "mysql-prod:backup:geheim123:3306"
  "mysql-dev:root:rootpass"
  "mysql-legacy"
)

# Diese Listen beeinflussen nur das Stoppen/Starten von Compose-Stacks
# waehrend des Backups.
# Sie schliessen keine Daten vom Dateibackup aus.
# Das Backup kopiert weiterhin den gesamten Inhalt von DOCKER_DIR.
EXCLUDED_STACK_DIRS=(
  "/srv/docker/infrastructure/gotify"
  "/srv/docker/infrastructure/ntpserver"
)

EXCLUDED_CONTAINER_NAMES=(
  "gotify"
)
